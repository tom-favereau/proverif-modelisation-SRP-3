(* Secret des cles de session *)
(* query cl:id, k:key; event(secret(cl,K) & attacker(k) ==> client_compromised(cl) || host_compromised()). *) (* TODO: client_compromised(cl) et host_compromised()*)

(* TODO : Faire les compromised : compromised le mdp ? La BDD du host ?, les clés privées ?*)

(* Processus Client *)
let Pc(cl:id) =
    new a:key;
    let A = pk_client(a) in
    out(c,(cl,A));
    in(c, x1:bitstring); 
    let (s:bitstring,B:key) = x1 in
    let p = get_password(cl) in
    let x = get_x(s,cl,p) in
    let u = get_u(B) in
    let K = shared_key_client(B,x,a,u) in
    (*event secretKClient(K); [A SUPPRIMER?]*)
    let M = client_proof(cl,s,A,B,K) in
    event startClient(cl,A,B,K); (* Le Client s'engage dans la session avec le Host*)
    out(c,M);
    in(c,=host_proof(A,M,K));
    event endClient(cl,A,B,K). (* Le Client a fini d'authentifier le Host*)

    (*
    if M_host = host_proof(A,M,K) then
        event sessionWithHost(cl);
    else 0.*)

(* Processus Host*)
let Ph() =
    in(c,x1:bitstring);
    let (cl:id,A:key) = x1 in
    let v = get_password_verifier(cl) in
    let s = get_salt(cl) in
    new b:key;
    let B = pk_host(b,v) in
    out(c,(s,B));
    let u = get_u(B) in
    let K = shared_key_host(A,v,u,b) in 
    event secretShared(cl,K); (* Clé connu par les 2. Doit être mis aussi/ou exclusif de l'autre côté ? Faire commen avant ?*)
    (*event secretKHost(K); [A SUPPRIMER?]*)
    in(c,M_client:bitstring);
    if M_client =  client_proof(cl,s,A,B,K) then
        event endHost(cl,A,B,K); (* Le Host a fini d'authentifier le Client*)
        let M = host_proof(A,M_client,K) in
        event startHost(cl,A,B,K); (* Le Host s'engage dans la session avec le Client*)
        out(c,M).

(* Processus pricipal *)
process !(in(c,cl:id);Pc(cl)) | !Ph() (* Ajouter le compromised *)