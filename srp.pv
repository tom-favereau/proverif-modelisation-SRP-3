query k:key; event(secretKClient(k)) && attacker(k).
query k:key; event(secretKHost(k)) && attacker(k).
query k:key; event(secretKClient(k)) ==> attacker(k). Cannot be proved
query k:key; event(secretKHost(k)) ==> attacker(k).  Cannot be proved
